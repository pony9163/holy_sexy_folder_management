{
  "name": "holy_sexy_folder_management",
  "version": "0.0.1",
  "description": "holy_sexy_folder_management —— 选择一个文件夹，查看其第一层文件的名称、类型、大小和修改日期",
  "main": "electron/main.js",
  "desktopName": "holy_sexy_folder_management",
  "author": {
    "name": "pony9163",
    "email": "286356700+pony9163@users.noreply.github.com"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder --linux deb"
  },
  "build": {
    "appId": "com.pony9163.holy-sexy-folder-management",
    "productName": "holy_sexy_folder_management",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "synopsis": "AI 文件夹整理工具",
      "syncDesktopName": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
